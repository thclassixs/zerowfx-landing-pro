---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const TOOL_IDS = [
  'pip-calculator','pip-value-calculator','lot-size-calculator','margin-calculator',
  'position-size-calculator','profit-calculator','risk-calculator','sl-tp-calculator',
  'spread-calculator','swap-calculator','drawdown-calculator','fibonacci-calculator',
  'pivot-points-calculator','leverage-calculator','commission-calculator','zero-strategy-calculator'
];

export function getStaticPaths() {
  const tools = [
    'pip-calculator','pip-value-calculator','lot-size-calculator','margin-calculator',
    'position-size-calculator','profit-calculator','risk-calculator','sl-tp-calculator',
    'spread-calculator','swap-calculator','drawdown-calculator','fibonacci-calculator',
    'pivot-points-calculator','leverage-calculator','commission-calculator','zero-strategy-calculator'
  ];
  return tools.map(tool => ({ params: { tool } }));
}

const { tool } = Astro.params;
const currentTool = TOOL_IDS.includes(tool) ? tool : TOOL_IDS[0];

// Generate a nice title from the tool slug
const toolTitle = currentTool.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
---

<Layout title={`${toolTitle} - Zerowfx`} description={`Free forex ${toolTitle.toLowerCase()}: calculate pips, lot size, margin, position size, profit, risk, fibonacci, pivot points and more.`}>
  <Navbar />
  <main class="tools-page">
    <div class="tools-container">
      <aside class="tools-sidebar" id="toolsSidebar">
        <div class="sidebar-header">
          <i data-lucide="calculator" class="sidebar-icon"></i>
          <h2 data-i18n="tools.sidebar.title">Trading Tools</h2>
        </div>
        <nav class="sidebar-nav" id="sidebarNav"></nav>
      </aside>
      <section class="tools-content">
        <div class="tool-panel" id="toolPanel">
          <div class="tool-header" id="toolHeader"></div>
          <div class="tool-body">
            <form class="tool-form" id="toolForm"></form>
            <div class="tool-results" id="toolResults">
              <div class="results-placeholder">
                <i data-lucide="bar-chart-3"></i>
                <p data-i18n="tools.results.placeholder">Results will appear here</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<div id="activeToolData" data-tool={currentTool} style="display:none;"></div>

<script is:inline>
const PAIRS = ['EUR/USD','GBP/USD','USD/JPY','USD/CHF','AUD/USD','NZD/USD','USD/CAD','EUR/GBP','EUR/JPY','GBP/JPY','AUD/JPY','EUR/AUD','EUR/CAD','EUR/CHF','GBP/AUD','GBP/CAD','GBP/CHF','AUD/CAD','AUD/CHF','AUD/NZD','NZD/CAD','NZD/CHF','NZD/JPY','CAD/JPY','CAD/CHF','CHF/JPY','XAU/USD','XAG/USD'];
const ACCS = ['USD','EUR','GBP','JPY','CHF','AUD','NZD','CAD'];

// Approximate exchange rates for conversion (when live rates unavailable)
const APPROX_RATES = {
  'USD':1,'EUR':1.08,'GBP':1.27,'JPY':0.0067,'CHF':1.13,'AUD':0.65,'NZD':0.61,'CAD':0.74
};

// Shared helper: get pip value per standard lot in USD for any pair
// Formula: Pip Value = (One Pip / Quote Rate to USD) ├Ś Contract Size
function getPipValue(pair, lots) {
  lots = lots || 1;
  const isJpy = pair.includes('JPY');
  const isXau = pair.startsWith('XAU');
  const isXag = pair.startsWith('XAG');
  const pipSize = isJpy ? 0.01 : 0.0001;
  const contractSize = isXau ? 100 : isXag ? 5000 : 100000;
  const quote = pair.split('/')[1];
  // Convert pip to USD: pip ├Ś contractSize, then convert from quote currency to USD
  let pipValueUSD = pipSize * contractSize;
  if (quote !== 'USD') {
    // Convert from quote currency to USD
    const quoteToUSD = APPROX_RATES[quote] || 1;
    pipValueUSD = pipValueUSD * quoteToUSD;
  }
  return pipValueUSD * lots;
}

// Get pip value in account currency
function getPipValueInAcc(pair, lots, accCurrency) {
  const pipUSD = getPipValue(pair, lots);
  if (accCurrency === 'USD') return pipUSD;
  const accToUSD = APPROX_RATES[accCurrency] || 1;
  return pipUSD / accToUSD;
}

const TOOLS = [
  {id:'pip-calculator',name:'Pip Calculator',icon:'trending-up',desc:'Calculate pips between entry and exit prices',
    fields:[
      {id:'pair',label:'Currency Pair',type:'select',options:PAIRS,val:'EUR/USD'},
      {id:'entry',label:'Entry Price',type:'number',placeholder:'1.08500',step:'0.00001'},
      {id:'exit',label:'Exit Price',type:'number',placeholder:'1.09000',step:'0.00001'}
    ],
    calc:f=>{
      const pair=f.pair,entry=parseFloat(f.entry),exit=parseFloat(f.exit);
      if(isNaN(entry)||isNaN(exit))return null;
      const isJpy=pair.includes('JPY');
      const pipSize=isJpy?0.01:0.0001;
      const pips=((exit-entry)/pipSize);
      const dir=pips>=0?'Buy (Long)':'Sell (Short)';
      return[{l:'Pips',v:pips.toFixed(1)},{l:'Direction',v:dir},{l:'Pip Size',v:pipSize},{l:'Price Difference',v:(exit-entry).toFixed(5)}];
    }
  },
  {id:'pip-value-calculator',name:'Pip Value Calculator',icon:'dollar-sign',desc:'Calculate how much 1 pip is worth in your account currency',
    fields:[
      {id:'pair',label:'Currency Pair',type:'select',options:PAIRS,val:'EUR/USD'},
      {id:'lots',label:'Lot Size',type:'number',placeholder:'1.00',step:'0.01',val:'1'},
      {id:'acc',label:'Account Currency',type:'select',options:ACCS,val:'USD'}
    ],
    calc:f=>{
      const lots=parseFloat(f.lots);if(isNaN(lots))return null;
      const isJpy=f.pair.includes('JPY');const pipSize=isJpy?0.01:0.0001;
      const isXau=f.pair.startsWith('XAU');const isXag=f.pair.startsWith('XAG');
      const contractSize=isXau?100:isXag?5000:100000;
      const units=lots*contractSize;
      const pipVal=getPipValueInAcc(f.pair, lots, f.acc);
      const symbol=f.acc==='USD'?'$':f.acc+' ';
      return[{l:'Pip Value',v:symbol+pipVal.toFixed(2)},{l:'Units',v:units.toLocaleString()},{l:'Pip Size',v:pipSize},{l:'Lot Size',v:lots+' lot(s)'},{l:'Contract Size',v:contractSize.toLocaleString()+' units/lot'}];
    }
  },
  {id:'lot-size-calculator',name:'Lot Size Calculator',icon:'layers',desc:'Calculate correct lot size based on account balance, risk %, and stop loss pips',
    fields:[
      {id:'balance',label:'Account Balance ($)',type:'number',placeholder:'10000',step:'1'},
      {id:'risk',label:'Risk Percentage (%)',type:'number',placeholder:'2',step:'0.1',val:'2'},
      {id:'slPips',label:'Stop Loss (Pips)',type:'number',placeholder:'50',step:'1'},
      {id:'pipVal',label:'Pip Value per Lot ($)',type:'number',placeholder:'10',step:'0.01',val:'10'}
    ],
    calc:f=>{
      const b=parseFloat(f.balance),r=parseFloat(f.risk),sl=parseFloat(f.slPips),pv=parseFloat(f.pipVal);
      if([b,r,sl,pv].some(isNaN)||sl===0||pv===0)return null;
      const riskAmt=b*(r/100);const lots=riskAmt/(sl*pv);
      return[{l:'Lot Size',v:lots.toFixed(2)},{l:'Risk Amount',v:'$'+riskAmt.toFixed(2)},{l:'Units',v:Math.round(lots*100000).toLocaleString()},{l:'Mini Lots',v:(lots*10).toFixed(2)},{l:'Micro Lots',v:(lots*100).toFixed(2)}];
    }
  },
  {id:'margin-calculator',name:'Margin Calculator',icon:'lock',desc:'Calculate required margin for any position based on lot size, leverage, and price',
    fields:[
      {id:'pair',label:'Currency Pair',type:'select',options:PAIRS,val:'EUR/USD'},
      {id:'lots',label:'Lot Size',type:'number',placeholder:'1.00',step:'0.01',val:'1'},
      {id:'price',label:'Current Price',type:'number',placeholder:'1.08500',step:'0.00001'},
      {id:'leverage',label:'Leverage',type:'select',options:['1:10','1:20','1:30','1:50','1:100','1:200','1:500','1:1000'],val:'1:100'}
    ],
    calc:f=>{
      const lots=parseFloat(f.lots),price=parseFloat(f.price),lev=parseInt(f.leverage.split(':')[1]);
      if(isNaN(lots)||isNaN(price)||isNaN(lev)||lev===0)return null;
      const units=lots*100000;const notional=units*price;const margin=notional/lev;
      return[{l:'Required Margin',v:'$'+margin.toFixed(2)},{l:'Notional Value',v:'$'+notional.toFixed(2)},{l:'Leverage',v:f.leverage},{l:'Units',v:units.toLocaleString()}];
    }
  },
  {id:'position-size-calculator',name:'Position Size Calculator',icon:'target',desc:'Calculate optimal trade size based on account balance, risk %, and stop loss',
    fields:[
      {id:'balance',label:'Account Balance ($)',type:'number',placeholder:'10000',step:'1'},
      {id:'risk',label:'Risk Percentage (%)',type:'number',placeholder:'2',step:'0.1',val:'2'},
      {id:'slPips',label:'Stop Loss (Pips)',type:'number',placeholder:'50',step:'1'},
      {id:'pair',label:'Currency Pair',type:'select',options:PAIRS,val:'EUR/USD'}
    ],
    calc:f=>{
      const b=parseFloat(f.balance),r=parseFloat(f.risk),sl=parseFloat(f.slPips);
      if([b,r,sl].some(isNaN)||sl===0)return null;
      const pipValPerLot=getPipValue(f.pair, 1);
      const riskAmt=b*(r/100);
      const lots=riskAmt/(sl*pipValPerLot);
      const isXau=f.pair.startsWith('XAU');const isXag=f.pair.startsWith('XAG');
      const contractSize=isXau?100:isXag?5000:100000;
      const units=Math.round(lots*contractSize);
      return[{l:'Position Size',v:lots.toFixed(2)+' lots'},{l:'Units',v:units.toLocaleString()},{l:'Risk Amount',v:'$'+riskAmt.toFixed(2)},{l:'Pip Value',v:'$'+pipValPerLot.toFixed(2)+'/lot'}];
    }
  },
  {id:'profit-calculator',name:'Profit Calculator',icon:'badge-dollar-sign',desc:'Calculate profit or loss based on entry price, exit price, and lot size',
    fields:[
      {id:'pair',label:'Currency Pair',type:'select',options:PAIRS,val:'EUR/USD'},
      {id:'direction',label:'Direction',type:'select',options:['Buy','Sell'],val:'Buy'},
      {id:'entry',label:'Entry Price',type:'number',placeholder:'1.08500',step:'0.00001'},
      {id:'exit',label:'Exit Price',type:'number',placeholder:'1.09000',step:'0.00001'},
      {id:'lots',label:'Lot Size',type:'number',placeholder:'1.00',step:'0.01',val:'1'}
    ],
    calc:f=>{
      const entry=parseFloat(f.entry),exit=parseFloat(f.exit),lots=parseFloat(f.lots);
      if([entry,exit,lots].some(isNaN))return null;
      const isJpy=f.pair.includes('JPY');const pipSize=isJpy?0.01:0.0001;
      const isXau=f.pair.startsWith('XAU');const isXag=f.pair.startsWith('XAG');
      const contractSize=isXau?100:isXag?5000:100000;
      let priceDiff=exit-entry;if(f.direction==='Sell')priceDiff=-priceDiff;
      const pips=priceDiff/pipSize;
      // Profit = price diff ├Ś lots ├Ś contract size (then convert from quote to USD if needed)
      const quote=f.pair.split('/')[1];
      let profit=priceDiff*lots*contractSize;
      if(quote!=='USD'){
        const quoteToUSD=APPROX_RATES[quote]||1;
        profit=profit*quoteToUSD;
      }
      return[{l:'Profit/Loss',v:(profit>=0?'+$':'Ôłĺ$')+Math.abs(profit).toFixed(2),cls:profit>=0?'positive':'negative'},{l:'Pips',v:pips.toFixed(1)},{l:'Direction',v:f.direction},{l:'Lot Size',v:lots}];
    }
  },
  {id:'risk-calculator',name:'Risk Calculator',icon:'shield-alert',desc:'Calculate risk amount and risk-to-reward ratio',
    fields:[
      {id:'balance',label:'Account Balance ($)',type:'number',placeholder:'10000',step:'1'},
      {id:'risk',label:'Risk Percentage (%)',type:'number',placeholder:'2',step:'0.1',val:'2'},
      {id:'slPips',label:'Stop Loss (Pips)',type:'number',placeholder:'50',step:'1'},
      {id:'tpPips',label:'Take Profit (Pips)',type:'number',placeholder:'100',step:'1'}
    ],
    calc:f=>{
      const b=parseFloat(f.balance),r=parseFloat(f.risk),sl=parseFloat(f.slPips),tp=parseFloat(f.tpPips);
      if([b,r,sl].some(isNaN))return null;
      const riskAmt=b*(r/100);const rr=!isNaN(tp)&&sl!==0?(tp/sl):0;const reward=riskAmt*rr;
      const res=[{l:'Risk Amount',v:'$'+riskAmt.toFixed(2)},{l:'% of Balance',v:r.toFixed(1)+'%'}];
      if(rr>0){res.push({l:'Risk:Reward',v:'1:'+rr.toFixed(2)});res.push({l:'Potential Reward',v:'$'+reward.toFixed(2)});}
      return res;
    }
  },
  {id:'sl-tp-calculator',name:'Stop Loss & Take Profit',icon:'arrow-down-up',desc:'Calculate SL/TP levels and risk-to-reward ratio',
    fields:[
      {id:'entry',label:'Entry Price',type:'number',placeholder:'1.08500',step:'0.00001'},
      {id:'direction',label:'Direction',type:'select',options:['Buy','Sell'],val:'Buy'},
      {id:'slPips',label:'Stop Loss (Pips)',type:'number',placeholder:'50',step:'1'},
      {id:'tpPips',label:'Take Profit (Pips)',type:'number',placeholder:'100',step:'1'},
      {id:'pair',label:'Currency Pair',type:'select',options:PAIRS,val:'EUR/USD'}
    ],
    calc:f=>{
      const entry=parseFloat(f.entry),slP=parseFloat(f.slPips),tpP=parseFloat(f.tpPips);
      if([entry,slP,tpP].some(isNaN))return null;
      const isJpy=f.pair.includes('JPY');const pip=isJpy?0.01:0.0001;
      const isBuy=f.direction==='Buy';
      const sl=isBuy?entry-slP*pip:entry+slP*pip;const tp=isBuy?entry+tpP*pip:entry-tpP*pip;
      const rr=slP!==0?(tpP/slP):0;
      return[{l:'Stop Loss Price',v:sl.toFixed(5),cls:'negative'},{l:'Take Profit Price',v:tp.toFixed(5),cls:'positive'},{l:'Risk:Reward',v:'1:'+rr.toFixed(2)},{l:'SL Distance',v:slP+' pips'},{l:'TP Distance',v:tpP+' pips'}];
    }
  },
  {id:'spread-calculator',name:'Spread Cost Calculator',icon:'arrow-left-right',desc:'Calculate spread cost in your account currency for any lot size',
    fields:[
      {id:'spread',label:'Spread (Pips)',type:'number',placeholder:'1.5',step:'0.1'},
      {id:'lots',label:'Lot Size',type:'number',placeholder:'1.00',step:'0.01',val:'1'},
      {id:'pair',label:'Currency Pair',type:'select',options:PAIRS,val:'EUR/USD'}
    ],
    calc:f=>{
      const spread=parseFloat(f.spread),lots=parseFloat(f.lots);
      if([spread,lots].some(isNaN))return null;
      // Spread Cost = Spread (pips) ├Ś Pip Value per lot ├Ś lots
      const pipValPerLot=getPipValue(f.pair, 1);
      const cost=spread*pipValPerLot*lots;
      const miniCost=spread*getPipValue(f.pair, 0.1);
      const microCost=spread*getPipValue(f.pair, 0.01);
      return[{l:'Spread Cost',v:'$'+cost.toFixed(2)},{l:'Per Mini Lot',v:'$'+miniCost.toFixed(2)},{l:'Per Micro Lot',v:'$'+microCost.toFixed(2)},{l:'Spread',v:spread+' pips'}];
    }
  },
  {id:'swap-calculator',name:'Swap Calculator',icon:'repeat',desc:'Calculate overnight swap/rollover fees for holding positions',
    fields:[
      {id:'pair',label:'Currency Pair',type:'select',options:PAIRS,val:'EUR/USD'},
      {id:'direction',label:'Direction',type:'select',options:['Buy (Long)','Sell (Short)'],val:'Buy (Long)'},
      {id:'lots',label:'Lot Size',type:'number',placeholder:'1.00',step:'0.01',val:'1'},
      {id:'swapRate',label:'Swap Rate (points)',type:'number',placeholder:'-3.5',step:'0.01'},
      {id:'days',label:'Days Held',type:'number',placeholder:'1',step:'1',val:'1'}
    ],
    calc:f=>{
      const lots=parseFloat(f.lots),rate=parseFloat(f.swapRate),days=parseFloat(f.days);
      if([lots,rate,days].some(isNaN))return null;
      const isJpy=f.pair.includes('JPY');const pointVal=isJpy?100000*0.001:100000*0.00001;
      const daily=rate*pointVal*lots;const total=daily*days;
      const wed=days>=3?daily*3:0;
      return[{l:'Daily Swap',v:(daily>=0?'+$':'Ôłĺ$')+Math.abs(daily).toFixed(2),cls:daily>=0?'positive':'negative'},{l:'Total Swap ('+days+' days)',v:(total>=0?'+$':'Ôłĺ$')+Math.abs(total).toFixed(2),cls:total>=0?'positive':'negative'},{l:'Triple Wednesday',v:(wed>=0?'+$':'Ôłĺ$')+Math.abs(wed).toFixed(2)},{l:'Swap Rate',v:rate+' points'}];
    }
  },
  {id:'drawdown-calculator',name:'Drawdown Calculator',icon:'trending-down',desc:'Calculate account drawdown, recovery needed, and consecutive loss impact',
    fields:[
      {id:'balance',label:'Starting Balance ($)',type:'number',placeholder:'10000',step:'1'},
      {id:'lossPercent',label:'Loss Per Trade (%)',type:'number',placeholder:'2',step:'0.1',val:'2'},
      {id:'consecutiveLosses',label:'Consecutive Losses',type:'number',placeholder:'5',step:'1',val:'5'}
    ],
    calc:f=>{
      const bal=parseFloat(f.balance),lossPct=parseFloat(f.lossPercent),n=parseInt(f.consecutiveLosses);
      if([bal,lossPct,n].some(isNaN)||bal===0)return null;
      // Simulate consecutive losses
      let current=bal;
      const results=[];
      results.push({l:'Starting Balance',v:'$'+bal.toFixed(2)});
      results.push({l:'ÔÇö After Each Loss ÔÇö',v:'',cls:'section'});
      for(let i=1;i<=n;i++){
        current=current*(1-lossPct/100);
        results.push({l:'After Loss #'+i,v:'$'+current.toFixed(2),cls:'negative'});
      }
      results.push({l:'ÔÇö Summary ÔÇö',v:'',cls:'section'});
      const totalLoss=bal-current;
      const ddPct=(totalLoss/bal)*100;
      const recovPct=(totalLoss/current)*100;
      results.push({l:'Final Balance',v:'$'+current.toFixed(2)});
      results.push({l:'Total Drawdown',v:ddPct.toFixed(2)+'%',cls:'negative'});
      results.push({l:'Total Loss',v:'$'+totalLoss.toFixed(2),cls:'negative'});
      results.push({l:'Recovery Needed',v:recovPct.toFixed(2)+'%',cls:'warning'});
      return results;
    }
  },
  {id:'fibonacci-calculator',name:'Fibonacci Calculator',icon:'git-branch',desc:'Calculate Fibonacci retracement and extension levels',
    fields:[
      {id:'direction',label:'Trend',type:'select',options:['Uptrend','Downtrend'],val:'Uptrend'},
      {id:'high',label:'High Price',type:'number',placeholder:'1.10000',step:'0.00001'},
      {id:'low',label:'Low Price',type:'number',placeholder:'1.05000',step:'0.00001'}
    ],
    calc:f=>{
      let high=parseFloat(f.high),low=parseFloat(f.low);
      if([high,low].some(isNaN))return null;
      const diff=high-low;const levels=[0,0.236,0.382,0.5,0.618,0.786,1];
      const exts=[1.0,1.382,1.618,2.0,2.618];const dec=high>100?2:5;
      const isUp=f.direction==='Uptrend';
      const res=[];
      res.push({l:'ÔÇö Retracement Levels ÔÇö',v:'',cls:'section'});
      levels.forEach(lv=>{
        const price=isUp?high-diff*lv:low+diff*lv;
        res.push({l:(lv*100).toFixed(1)+'%',v:price.toFixed(dec)});
      });
      res.push({l:'ÔÇö Extension Levels ÔÇö',v:'',cls:'section'});
      exts.forEach(lv=>{
        const price=isUp?high+diff*(lv-1):low-diff*(lv-1);
        res.push({l:(lv*100).toFixed(1)+'%',v:price.toFixed(dec)});
      });
      return res;
    }
  },
  {id:'pivot-points-calculator',name:'Pivot Points Calculator',icon:'navigation',desc:'Calculate Standard, Fibonacci, Camarilla, and Woodie pivot points',
    fields:[
      {id:'high',label:'Previous High',type:'number',placeholder:'1.10000',step:'0.00001'},
      {id:'low',label:'Previous Low',type:'number',placeholder:'1.05000',step:'0.00001'},
      {id:'close',label:'Previous Close',type:'number',placeholder:'1.08000',step:'0.00001'},
      {id:'method',label:'Method',type:'select',options:['Standard','Fibonacci','Camarilla','Woodie'],val:'Standard'}
    ],
    calc:f=>{
      const h=parseFloat(f.high),l=parseFloat(f.low),c=parseFloat(f.close);
      if([h,l,c].some(isNaN))return null;
      const dec=h>100?2:5;const r=[];
      if(f.method==='Standard'){
        const p=(h+l+c)/3;
        r.push({l:'R3',v:(2*p-2*l+h).toFixed(dec),cls:'positive'});
        r.push({l:'R2',v:(p+(h-l)).toFixed(dec),cls:'positive'});
        r.push({l:'R1',v:(2*p-l).toFixed(dec),cls:'positive'});
        r.push({l:'Pivot',v:p.toFixed(dec),cls:'section'});
        r.push({l:'S1',v:(2*p-h).toFixed(dec),cls:'negative'});
        r.push({l:'S2',v:(p-(h-l)).toFixed(dec),cls:'negative'});
        r.push({l:'S3',v:(2*p-2*h+l).toFixed(dec),cls:'negative'});
      } else if(f.method==='Fibonacci'){
        const p=(h+l+c)/3;const d=h-l;
        r.push({l:'R3',v:(p+d*1.0).toFixed(dec),cls:'positive'});
        r.push({l:'R2',v:(p+d*0.618).toFixed(dec),cls:'positive'});
        r.push({l:'R1',v:(p+d*0.382).toFixed(dec),cls:'positive'});
        r.push({l:'Pivot',v:p.toFixed(dec),cls:'section'});
        r.push({l:'S1',v:(p-d*0.382).toFixed(dec),cls:'negative'});
        r.push({l:'S2',v:(p-d*0.618).toFixed(dec),cls:'negative'});
        r.push({l:'S3',v:(p-d*1.0).toFixed(dec),cls:'negative'});
      } else if(f.method==='Camarilla'){
        const d=h-l;
        r.push({l:'R4',v:(c+d*1.1/2).toFixed(dec),cls:'positive'});
        r.push({l:'R3',v:(c+d*1.1/4).toFixed(dec),cls:'positive'});
        r.push({l:'R2',v:(c+d*1.1/6).toFixed(dec),cls:'positive'});
        r.push({l:'R1',v:(c+d*1.1/12).toFixed(dec),cls:'positive'});
        r.push({l:'Pivot',v:((h+l+c)/3).toFixed(dec),cls:'section'});
        r.push({l:'S1',v:(c-d*1.1/12).toFixed(dec),cls:'negative'});
        r.push({l:'S2',v:(c-d*1.1/6).toFixed(dec),cls:'negative'});
        r.push({l:'S3',v:(c-d*1.1/4).toFixed(dec),cls:'negative'});
        r.push({l:'S4',v:(c-d*1.1/2).toFixed(dec),cls:'negative'});
      } else {
        const p=(h+l+2*c)/4;
        r.push({l:'R3',v:(h+2*(p-l)).toFixed(dec),cls:'positive'});
        r.push({l:'R2',v:(p+(h-l)).toFixed(dec),cls:'positive'});
        r.push({l:'R1',v:(2*p-l).toFixed(dec),cls:'positive'});
        r.push({l:'Pivot',v:p.toFixed(dec),cls:'section'});
        r.push({l:'S1',v:(2*p-h).toFixed(dec),cls:'negative'});
        r.push({l:'S2',v:(p-(h-l)).toFixed(dec),cls:'negative'});
        r.push({l:'S3',v:(l-2*(h-p)).toFixed(dec),cls:'negative'});
      }
      return r;
    }
  },
  {id:'leverage-calculator',name:'Leverage Calculator',icon:'zap',desc:'Calculate margin requirements and buying power for different leverage ratios',
    fields:[
      {id:'balance',label:'Account Balance ($)',type:'number',placeholder:'10000',step:'1'},
      {id:'leverage',label:'Leverage',type:'select',options:['1:10','1:20','1:30','1:50','1:100','1:200','1:500','1:1000'],val:'1:100'},
      {id:'price',label:'Asset Price',type:'number',placeholder:'1.08500',step:'0.00001'}
    ],
    calc:f=>{
      const bal=parseFloat(f.balance),lev=parseInt(f.leverage.split(':')[1]),price=parseFloat(f.price);
      if([bal,lev,price].some(isNaN)||price===0)return null;
      const power=bal*lev;const maxUnits=Math.floor(power/price);const maxLots=(maxUnits/100000);
      const marginPerLot=(100000*price)/lev;
      return[{l:'Buying Power',v:'$'+power.toLocaleString()},{l:'Max Position',v:maxLots.toFixed(2)+' lots'},{l:'Max Units',v:maxUnits.toLocaleString()},{l:'Margin per Lot',v:'$'+marginPerLot.toFixed(2)},{l:'Leverage Ratio',v:f.leverage}];
    }
  },
  {id:'commission-calculator',name:'Commission Calculator',icon:'receipt',desc:'Calculate trading commissions, round-trip costs, and break-even pips',
    fields:[
      {id:'commission',label:'Commission per Lot ($)',type:'number',placeholder:'7',step:'0.01',val:'7'},
      {id:'lots',label:'Lot Size',type:'number',placeholder:'1.00',step:'0.01',val:'1'},
      {id:'pair',label:'Currency Pair',type:'select',options:PAIRS,val:'EUR/USD'},
      {id:'roundTrip',label:'Round Trip',type:'select',options:['Yes','No'],val:'Yes'}
    ],
    calc:f=>{
      const comm=parseFloat(f.commission),lots=parseFloat(f.lots);
      if([comm,lots].some(isNaN))return null;
      const oneway=comm*lots;const rt=f.roundTrip==='Yes'?oneway*2:oneway;
      // Break-even pips = round-trip commission / pip value
      const pipValPerLot=getPipValue(f.pair, 1);
      const bePips=rt/(pipValPerLot*lots);
      return[{l:'One-Way Cost',v:'$'+oneway.toFixed(2)},{l:'Round-Trip Cost',v:'$'+rt.toFixed(2)},{l:'Break-Even Pips',v:bePips.toFixed(2)+' pips'},{l:'Cost per $100k',v:'$'+(comm).toFixed(2)}];
    }
  },
  {id:'zero-strategy-calculator',name:'ZERO-Strategy Calculator',icon:'line-chart',desc:'Simulate account growth based on your win rate, risk per trade, and risk:reward ratio (ZERO Strategy)',
    fields:[
      {id:'startBalance',label:'Start Balance ($)',type:'number',placeholder:'10000',step:'1',val:'10000'},
      {id:'numTrades',label:'Number of Trades',type:'number',placeholder:'20',step:'1',val:'20'},
      {id:'riskPct',label:'Typical Risk (%)',type:'number',placeholder:'2',step:'0.1',val:'2'},
      {id:'rrRatio',label:'Risk:Reward (1:X)',type:'number',placeholder:'2',step:'0.1',val:'2'},
      {id:'winPct',label:'Win/Loss (%)',type:'number',placeholder:'55',step:'1',val:'55'}
    ],
    calc:f=>{
      const bal=parseFloat(f.startBalance),n=parseInt(f.numTrades),riskPct=parseFloat(f.riskPct),rr=parseFloat(f.rrRatio),winPct=parseFloat(f.winPct);
      if([bal,n,riskPct,rr,winPct].some(isNaN)||bal<=0||n<=0)return null;
      const winRate=winPct/100;
      const totalWins=Math.round(n*winRate);
      const totalLosses=n-totalWins;
      // Simulate trades: distribute wins evenly among trades
      let current=bal;
      let peak=bal;
      let maxDD=0;
      let gross=0;
      let grossLoss=0;
      const res=[];
      res.push({l:'Starting Balance',v:'$'+bal.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})});
      res.push({l:'ÔÇö Trade Simulation ÔÇö',v:'',cls:'section'});
      // Interleave wins and losses realistically
      let winsLeft=totalWins;
      let lossesLeft=totalLosses;
      for(let i=1;i<=n;i++){
        const riskAmt=current*(riskPct/100);
        // Determine if this trade is a win
        let isWin=false;
        const remaining=n-i+1;
        if(lossesLeft===0){isWin=true;}
        else if(winsLeft===0){isWin=false;}
        else{isWin=Math.random()<(winsLeft/remaining);}
        let pnl;
        if(isWin){
          pnl=riskAmt*rr;
          winsLeft--;
          gross+=pnl;
        }else{
          pnl=-riskAmt;
          lossesLeft--;
          grossLoss+=riskAmt;
        }
        current+=pnl;
        if(current>peak)peak=current;
        const dd=peak>0?((peak-current)/peak)*100:0;
        if(dd>maxDD)maxDD=dd;
        if(n<=30){
          res.push({l:'Trade #'+i+(isWin?' Ôťô':' ÔťŚ'),v:(pnl>=0?'+$':'Ôłĺ$')+Math.abs(pnl).toFixed(2)+' Ôćĺ $'+current.toFixed(2),cls:isWin?'positive':'negative'});
        }
      }
      if(n>30){
        res.push({l:'('+n+' trades simulated)',v:'Showing summary only',cls:''});
      }
      res.push({l:'ÔÇö Summary ÔÇö',v:'',cls:'section'});
      const totalPnl=current-bal;
      const returnPct=((current-bal)/bal)*100;
      const profitFactor=grossLoss>0?(gross/grossLoss):gross>0?Infinity:0;
      const expectancy=(totalPnl/n);
      res.push({l:'Final Balance',v:'$'+current.toFixed(2),cls:current>=bal?'positive':'negative'});
      res.push({l:'Total P&L',v:(totalPnl>=0?'+$':'Ôłĺ$')+Math.abs(totalPnl).toFixed(2),cls:totalPnl>=0?'positive':'negative'});
      res.push({l:'Return',v:(returnPct>=0?'+':'')+returnPct.toFixed(2)+'%',cls:returnPct>=0?'positive':'negative'});
      res.push({l:'Wins / Losses',v:totalWins+' / '+totalLosses});
      res.push({l:'Win Rate',v:winPct.toFixed(1)+'%'});
      res.push({l:'Profit Factor',v:profitFactor===Infinity?'Ôł×':profitFactor.toFixed(2)});
      res.push({l:'Avg Trade',v:(expectancy>=0?'+$':'Ôłĺ$')+Math.abs(expectancy).toFixed(2)});
      res.push({l:'Max Drawdown',v:maxDD.toFixed(2)+'%',cls:'negative'});
      res.push({l:'Risk:Reward',v:'1:'+rr.toFixed(1)});
      return res;
    }
  }
];

// Get active tool from the data attribute (set by Astro server-side)
let activeTool = document.getElementById('activeToolData')?.dataset.tool || TOOLS[0].id;

function _t(text) {
  if (!text) return '';
  if (typeof text !== 'string') text = String(text);
  const lang = window.currentLang || 'en';
  if (lang === 'en') return text;
  
  if (window.i18nData && window.i18nData[lang] && window.i18nData[lang][text]) {
    return window.i18nData[lang][text];
  }
  return text;
}

function init(){
  const nav=document.getElementById('sidebarNav');
  nav.innerHTML=TOOLS.map(t=>`<a href="/tools/${t.id}" class="sidebar-btn${t.id===activeTool?' active':''}" data-tool="${t.id}"><i data-lucide="${t.icon}"></i><span>${_t(t.name)}</span></a>`).join('');
  renderTool();
  if(window.lucide)window.lucide.createIcons();
}

function renderTool(){
  const t=TOOLS.find(x=>x.id===activeTool);if(!t)return;
  const isCOT=t.id==='zero-strategy-calculator';
  document.getElementById('toolHeader').innerHTML=`<div class="tool-title-row"><i data-lucide="${t.icon}"></i><h1>${_t(t.name)}</h1></div><p class="tool-desc">${_t(t.desc)}</p>`;
  const form=document.getElementById('toolForm');
  form.innerHTML=t.fields.map(f=>{
    const fLabel = _t(f.label);
    const fPlaceholder = _t(f.placeholder||'');
    if(f.type==='select'){
      const opts=(f.options||[]).map(o=>`<option value="${o}"${o===f.val?' selected':''}>${_t(o)}</option>`).join('');
      return`<div class="form-group"><label for="${f.id}">${fLabel}</label><select id="${f.id}" class="form-control">${opts}</select></div>`;
    }
    if(isCOT && f.type==='number'){
      let extra='';
      if(f.id==='rrRatio'){
        extra=`<div class="rr-presets"><button type="button" class="rr-preset-btn" data-rr="2">RR 1:2</button><button type="button" class="rr-preset-btn" data-rr="3">RR 1:3</button></div>`;
      }
      return`<div class="form-group"><label for="${f.id}">${fLabel}</label><div class="stepper-row"><input id="${f.id}" type="number" class="form-control stepper-input" placeholder="${fPlaceholder}" step="${f.step||'any'}" ${f.val?'value="'+f.val+'"':''}><button type="button" class="stepper-btn stepper-minus" data-target="${f.id}" data-step="${f.step||1}">Ôłĺ</button><button type="button" class="stepper-btn stepper-plus" data-target="${f.id}" data-step="${f.step||1}">+</button></div>${extra}</div>`;
    }
    return`<div class="form-group"><label for="${f.id}">${fLabel}</label><input id="${f.id}" type="${f.type}" class="form-control" placeholder="${fPlaceholder}" step="${f.step||'any'}" ${f.val?'value="'+f.val+'"':''}></div>`;
  }).join('')+`<button type="submit" class="calc-btn"><i data-lucide="calculator"></i> ${_t("Calculate")}</button>`+(isCOT?`<button type="button" class="clear-btn" id="cotClearBtn"><i data-lucide="eraser"></i> ${_t("Clear all")}</button>`:'');
  form.onsubmit=e=>{e.preventDefault();calculate(t);};
  // Wire up COT-specific controls
  if(isCOT){
    form.querySelectorAll('.stepper-btn').forEach(btn=>{
      btn.addEventListener('click',()=>{
        const input=document.getElementById(btn.dataset.target);
        const step=parseFloat(btn.dataset.step)||1;
        let val=parseFloat(input.value)||0;
        if(btn.classList.contains('stepper-plus'))val+=step;
        else val=Math.max(0,val-step);
        input.value=parseFloat(val.toFixed(4));
      });
    });
    form.querySelectorAll('.rr-preset-btn').forEach(btn=>{
      btn.addEventListener('click',()=>{
        document.getElementById('rrRatio').value=btn.dataset.rr;
      });
    });
    const clearBtn=document.getElementById('cotClearBtn');
    if(clearBtn){
      clearBtn.addEventListener('click',()=>{
        t.fields.forEach(f=>{
          const el=document.getElementById(f.id);
          if(el)el.value='0';
        });
        document.getElementById('toolResults').innerHTML=`<div class="results-placeholder"><i data-lucide="bar-chart-3"></i><p>${_t("Enter values and click Calculate")}</p></div>`;
        if(window.lucide)window.lucide.createIcons();
      });
    }
  }
  document.getElementById('toolResults').innerHTML=`<div class="results-placeholder"><i data-lucide="bar-chart-3"></i><p>${_t("Enter values and click Calculate")}</p></div>`;
  if(window.lucide)window.lucide.createIcons();
}

function calculate(t){
  const vals={};t.fields.forEach(f=>{
    const el=document.getElementById(f.id);vals[f.id]=el?el.value:'';
  });
  const res=t.calc(vals);
  const panel=document.getElementById('toolResults');
  if(!res){panel.innerHTML=`<div class="results-placeholder error"><i data-lucide="alert-circle"></i><p>${_t("Please fill in all required fields")}</p></div>`;if(window.lucide)window.lucide.createIcons();return;}
  panel.innerHTML='<div class="results-grid">'+res.map(r=>{
    if(r.cls==='section')return`<div class="result-section">${_t(r.l)}</div>`;
    return`<div class="result-item${r.cls?' '+r.cls:''}"><span class="result-label">${_t(r.l)}</span><span class="result-value">${_t(r.v)}</span></div>`;
  }).join('')+'</div>';
  panel.classList.add('has-results');
  if(window.lucide)window.lucide.createIcons();
}

document.addEventListener('DOMContentLoaded',init);
window.addEventListener('languageChanged',init);

// Mobile sidebar toggle
document.addEventListener('DOMContentLoaded',()=>{
  const sb=document.getElementById('toolsSidebar');
  document.querySelector('.tools-content')?.addEventListener('click',()=>{if(window.innerWidth<900)sb.classList.remove('open');});
});
</script>

