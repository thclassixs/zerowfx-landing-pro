---
// /tools redirects to the default first tool, but checks for legacy hash URLs
---

<html>
  <head>
    <meta http-equiv="refresh" content="0;url=/tools/pip-calculator" />
    <title>Redirecting...</title>
  </head>
  <body>
    <script is:inline>
      const hash = window.location.hash.slice(1);
      if (hash) {
        window.location.replace('/tools/' + hash);
      } else {
        window.location.replace('/tools/pip-calculator');
      }
    </script>
  </body>
</html>
