---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Ticker from '../components/Ticker.astro';
import About from '../components/About.astro';
import Members from '../components/Members.astro';
import Setups from '../components/Setups.astro';
import Lifestyle from '../components/Lifestyle.astro';
import Results from '../components/Results.astro';
import Partners from '../components/Partners.astro';
import Footer from '../components/Footer.astro';
import StickyElements from '../components/StickyElements.astro';

const schemaData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Zerowfx",
    "url": "https://zerowfx.com",
    "logo": "https://zerowfx.com/logo.webp",
    "sameAs": [
      "https://www.youtube.com/@zerowfx1"
    ],
    "description": "Master the Forex markets with proven strategies and expert mentorship."
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Zerowfx",
    "url": "https://zerowfx.com",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://zerowfx.com/blog?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
]);
---

<Layout>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schemaData} />
  </Fragment>
  <Navbar />
  <Hero />
  <Ticker />
  <About />
  <Lifestyle />
  <Members />
  <Setups />
  <Results />
  <Partners />
  <Footer />
  <StickyElements />
</Layout>
