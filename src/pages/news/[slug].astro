---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

// Required for static builds - fetch all slugs from the DB at build time
export async function getStaticPaths() {
  try {
    const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001';
    const res = await fetch(`${API}/api/news/saved?page=1&limit=500`);
    if (res.ok) {
      const data = await res.json();
      return (data.articles || [])
        .filter(a => a.slug)
        .map(a => ({ params: { slug: a.slug } }));
    }
  } catch (e) {
    console.warn('Could not fetch article slugs for static paths:', e.message);
  }
  // Return empty array if API is unavailable (build will skip these pages)
  return [];
}

// Get slug from URL
const { slug } = Astro.params;
---

<Layout title="Loading Article..." description="News article on Zerowfx">
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet" />
  </Fragment>

  <Navbar />

  <main class="article-page">
    <!-- Loading State -->
    <div class="article-loading" id="articleLoading">
      <div class="spinner"></div>
      <p data-i18n="news.loading">Loading article...</p>
    </div>

    <!-- Error State -->
    <div class="article-error" id="articleError" style="display:none;">
      <i data-lucide="alert-circle" style="width:48px;height:48px;opacity:0.5;"></i>
      <h2>Article Not Found</h2>
      <p>The article you're looking for doesn't exist or has been removed.</p>
      <a href="/news" class="back-btn">← Back to News</a>
    </div>

    <!-- Article Content -->
    <article class="article-container" id="articleContainer" style="display:none;">
      <!-- Hero Image -->
      <div class="article-hero" id="articleHero">
        <div class="hero-overlay"></div>
        <div class="hero-inner">
          <div class="article-breadcrumb">
            <a href="/news">News</a>
            <span class="sep">›</span>
            <span class="breadcrumb-cat" id="articleCat">Article</span>
          </div>
          <h1 class="article-title" id="articleTitle">Loading...</h1>
          <div class="article-meta-row">
            <span class="meta-source" id="articleSource"></span>
            <span class="meta-dot">·</span>
            <span class="meta-date" id="articleDate"></span>
            <span class="meta-dot" id="langDot" style="display:none;">·</span>
            <span class="meta-lang" id="articleLang" style="display:none;"></span>
          </div>
        </div>
      </div>

      <!-- Article Body -->
      <div class="article-body">
        <!-- Summary Card -->
        <div class="summary-card" id="summaryCard" style="display:none;">
          <div class="summary-icon"><i data-lucide="sparkles"></i></div>
          <div class="summary-content">
            <span class="summary-label" data-i18n="news.ai_summary">AI Summary</span>
            <p class="summary-text" id="summaryText"></p>
          </div>
        </div>

        <!-- Main Content -->
        <div class="content-block" id="articleContent">
          Loading content...
        </div>

        <!-- Translation Badge -->
        <div class="translation-info" id="translationInfo" style="display:none;">
          <i data-lucide="languages"></i>
          <span id="translationLabel">Translated version</span>
        </div>

        <!-- Tags / Keywords -->
        <div class="article-tags" id="articleTags" style="display:none;"></div>

        <!-- Share Row -->
        <div class="share-row">
          <span class="share-label">Share:</span>
          <button class="share-btn" id="shareTwitter" title="Share on Twitter">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </button>
          <button class="share-btn" id="shareCopy" title="Copy link">
            <i data-lucide="link"></i>
          </button>
        </div>

        <!-- Source Link -->
        <div class="source-link-row" id="sourceLinkRow" style="display:none;">
          <a href="#" id="originalSourceLink" target="_blank" rel="noopener noreferrer" class="source-link">
            <i data-lucide="external-link"></i>
            <span data-i18n="news.view_source">View Original Source</span>
          </a>
        </div>

        <!-- Related Articles -->
        <div class="related-section" id="relatedSection" style="display:none;">
          <h3 class="related-title" data-i18n="news.related">More Articles</h3>
          <div class="related-grid" id="relatedGrid"></div>
        </div>
      </div>
    </article>

    <!-- Toast -->
    <div class="toast-container" id="toastContainer"></div>
  </main>

  <Footer />
</Layout>

<script is:inline define:vars={{ slug }}>
document.addEventListener('DOMContentLoaded', async () => {
  const API = (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') ? 'http://localhost:3001' : '';
  const lang = localStorage.getItem('language') || 'en';
  const isRtl = lang === 'ar';
  const needsTranslation = lang !== 'en';
  const t = (window.i18nData && window.i18nData[lang]) ? window.i18nData[lang] : (window.i18nData ? window.i18nData['en'] : {});

  const loadingEl = document.getElementById('articleLoading');
  const errorEl = document.getElementById('articleError');
  const containerEl = document.getElementById('articleContainer');

  try {
    const res = await fetch(`${API}/api/news/article/${slug}`);
    if (!res.ok) throw new Error('Not found');
    const article = await res.json();

    loadingEl.style.display = 'none';
    containerEl.style.display = 'block';

    // ── Determine display content based on language ──
    let displayTitle = article.title;
    let displayContent = article.content || article.description || '';
    let isTranslated = false;

    // Use AI rewritten content if available
    if (article.ai_rewritten_title) displayTitle = article.ai_rewritten_title;
    if (article.ai_rewritten_content) displayContent = article.ai_rewritten_content;

    // Use translated content if user language matches
    if (needsTranslation && article.ai_translation && article.translate_language === lang) {
      displayContent = article.ai_translation;
      isTranslated = true;
      // Use translated title if available
      if (article.ai_translated_title) {
        displayTitle = article.ai_translated_title;
      }
    }

    // Set RTL if Arabic
    if (isRtl) {
      containerEl.setAttribute('dir', 'rtl');
      containerEl.style.fontFamily = "'Cairo', sans-serif";
    }

    // ── Fill in the page ──
    document.title = displayTitle + ' - Zerowfx News';

    // Update meta tags
    const metaDesc = document.querySelector('meta[name="description"]');
    if (metaDesc) metaDesc.content = (article.ai_summary || article.description || displayContent).slice(0, 160);

    // Hero
    const heroEl = document.getElementById('articleHero');
    if (article.image_url) {
      heroEl.style.backgroundImage = `url(${article.image_url})`;
      heroEl.classList.add('has-image');
    }

    // Title
    document.getElementById('articleTitle').textContent = displayTitle;

    // Category
    let cat = article.category || '';
    cat = cat.replace(/[\[\]"]/g, '').trim();
    document.getElementById('articleCat').textContent = cat || 'News';

    // Source
    document.getElementById('articleSource').textContent = article.source_name || 'Market News';

    // Date
    document.getElementById('articleDate').textContent = article.published_at
      ? new Date(article.published_at).toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })
      : '';

    // Language badge
    if (isTranslated) {
      const langEl = document.getElementById('articleLang');
      const langDot = document.getElementById('langDot');
      const langLabels = { ar: '🇸🇦 العربية', fr: '🇫🇷 Français', es: '🇪🇸 Español', de: '🇩🇪 Deutsch' };
      langEl.textContent = langLabels[lang] || lang.toUpperCase();
      langEl.style.display = '';
      langDot.style.display = '';

      const transInfo = document.getElementById('translationInfo');
      transInfo.style.display = 'flex';
      const labels = { ar: 'تمت الترجمة بالذكاء الاصطناعي', fr: 'Traduit par IA', es: 'Traducido por IA' };
      document.getElementById('translationLabel').textContent = labels[lang] || 'AI Translated';
    }

    // Summary
    if (article.ai_summary) {
      const summaryCard = document.getElementById('summaryCard');
      summaryCard.style.display = 'flex';
      document.getElementById('summaryText').textContent = article.ai_summary;
    }

    // Content - convert newlines to paragraphs
    const contentEl = document.getElementById('articleContent');
    const paragraphs = displayContent.split(/\n\n+/).filter(Boolean);
    if (paragraphs.length > 1) {
      contentEl.innerHTML = paragraphs.map(p => `<p>${p.trim()}</p>`).join('');
    } else {
      contentEl.innerHTML = `<p>${displayContent}</p>`;
    }

    // Tags / Keywords
    if (article.keywords) {
      try {
        const keywords = typeof article.keywords === 'string' ? JSON.parse(article.keywords) : article.keywords;
        if (keywords && keywords.length > 0) {
          const tagsEl = document.getElementById('articleTags');
          tagsEl.style.display = 'flex';
          tagsEl.innerHTML = keywords.slice(0, 8).map(k =>
            `<span class="tag">${k}</span>`
          ).join('');
        }
      } catch {}
    }

    // Source link
    if (article.original_url) {
      const row = document.getElementById('sourceLinkRow');
      row.style.display = 'flex';
      document.getElementById('originalSourceLink').href = article.original_url;
    }

    // Share
    document.getElementById('shareTwitter').addEventListener('click', () => {
      const url = encodeURIComponent(window.location.href);
      const text = encodeURIComponent(displayTitle);
      window.open(`https://twitter.com/intent/tweet?url=${url}&text=${text}`, '_blank');
    });

    document.getElementById('shareCopy').addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href);
      showToast(t['news.copied'] || 'Link copied!', 'success');
    });

    // Load related articles
    try {
      const relRes = await fetch(`${API}/api/news/saved?page=1&limit=4&processed=1`);
      if (relRes.ok) {
        const relData = await relRes.json();
        const related = relData.articles.filter(a => a.slug !== slug).slice(0, 3);
        if (related.length > 0) {
          const section = document.getElementById('relatedSection');
          section.style.display = 'block';
          const grid = document.getElementById('relatedGrid');
          grid.innerHTML = related.map(r => {
            let rTitle = r.ai_rewritten_title || r.title;
            if (needsTranslation && r.ai_translation && r.translate_language === lang) {
              rTitle = r.ai_translated_title || r.ai_rewritten_title || r.title;
            }
            const rDate = r.published_at ? new Date(r.published_at).toLocaleDateString() : '';
            const rImg = r.image_url || 'https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?auto=format&fit=crop&q=80&w=400';
            return `
              <a href="/news/${r.slug}" class="related-card" ${isRtl ? 'dir="rtl"' : ''}>
                <img src="${rImg}" alt="" class="related-img" onerror="this.style.display='none'" loading="lazy" />
                <div class="related-info">
                  <h4 class="related-card-title">${rTitle}</h4>
                  <span class="related-date">${rDate}</span>
                </div>
              </a>
            `;
          }).join('');
        }
      }
    } catch {}

    // Init icons
    if (window.lucide) window.lucide.createIcons();

  } catch (err) {
    console.error(err);
    loadingEl.style.display = 'none';
    errorEl.style.display = 'flex';
  }

  function showToast(msg, type) {
    const c = document.getElementById('toastContainer');
    if (!c) return;
    const t = document.createElement('div');
    t.className = `toast toast-${type}`;
    t.textContent = msg;
    c.appendChild(t);
    setTimeout(() => t.classList.add('show'), 10);
    setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 300); }, 2500);
  }
});
</script>

<style>
  /* ── Article Page ── */
  .article-page {
    padding-top: 64px;
    min-height: 100vh;
    background: var(--color-bg);
  }

  /* Loading */
  .article-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    gap: 16px;
    color: var(--color-text-dim);
  }
  .spinner {
    width: 40px; height: 40px;
    border: 3px solid var(--color-border-strong);
    border-top-color: var(--color-green);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Error */
  .article-error {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    gap: 16px;
    color: var(--color-text-muted);
    text-align: center;
    padding: 40px 24px;
  }
  .article-error h2 { font-size: 1.5rem; font-weight: 700; margin: 0; }
  .back-btn {
    padding: 10px 24px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-weight: 600;
    transition: var(--transition);
  }
  .back-btn:hover { border-color: var(--color-green); color: var(--color-green); }

  /* Hero */
  .article-hero {
    position: relative;
    min-height: 360px;
    display: flex;
    align-items: flex-end;
    padding: 48px 24px;
    background-size: cover;
    background-position: center;
    background-color: var(--color-bg-card);
    border-bottom: 1px solid var(--color-border);
  }
  .article-hero.has-image .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.1) 100%);
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
  }

  /* Breadcrumb */
  .article-breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    font-size: 0.85rem;
  }
  .article-breadcrumb a {
    color: var(--color-green);
    font-weight: 600;
    transition: var(--transition);
  }
  .article-breadcrumb a:hover { opacity: 0.8; }
  .sep { color: var(--color-text-dim); }
  .breadcrumb-cat {
    color: var(--color-text-muted);
    text-transform: capitalize;
  }

  /* Title */
  .article-title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 800;
    line-height: 1.25;
    color: var(--color-text);
    margin-bottom: 16px;
  }

  /* Meta */
  .article-meta-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: var(--color-text-dim);
  }
  .meta-dot { opacity: 0.4; }
  .meta-source { font-weight: 600; color: var(--color-green); }
  .meta-lang {
    display: inline-block;
    padding: 2px 10px;
    background: rgba(34, 197, 94, 0.12);
    border-radius: 12px;
    font-size: 0.78rem;
    font-weight: 600;
  }

  /* Body */
  .article-body {
    max-width: 780px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }

  /* Summary Card */
  .summary-card {
    display: flex;
    gap: 16px;
    padding: 20px;
    background: rgba(34, 197, 94, 0.06);
    border: 1px solid rgba(34, 197, 94, 0.15);
    border-radius: var(--radius-lg);
    margin-bottom: 32px;
  }
  .summary-icon {
    flex-shrink: 0;
    width: 36px; height: 36px;
    background: rgba(34, 197, 94, 0.12);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-green);
  }
  .summary-icon i, .summary-icon svg { width: 18px; height: 18px; }
  .summary-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-green);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }
  .summary-text {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  /* Content */
  .content-block {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--color-text-muted);
  }
  .content-block :global(p) {
    margin-bottom: 20px;
  }
  .content-block :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Translation Info */
  .translation-info {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: rgba(34, 197, 94, 0.06);
    border-radius: var(--radius-md);
    font-size: 0.82rem;
    color: var(--color-green);
    margin-top: 24px;
  }
  .translation-info i, .translation-info svg { width: 16px; height: 16px; }

  /* Tags */
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }
  .tag {
    padding: 5px 14px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    font-size: 0.8rem;
    color: var(--color-text-dim);
    font-weight: 500;
  }

  /* Share */
  .share-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }
  .share-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-dim);
  }
  .share-btn {
    width: 40px; height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: var(--transition);
  }
  .share-btn:hover {
    border-color: var(--color-green);
    color: var(--color-green);
    transform: translateY(-2px);
  }
  .share-btn i, .share-btn svg { width: 18px; height: 18px; }

  /* Source link */
  .source-link-row {
    display: flex;
    margin-top: 20px;
  }
  .source-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 600;
    transition: var(--transition);
  }
  .source-link:hover { border-color: var(--color-green); color: var(--color-green); }
  .source-link i, .source-link svg { width: 16px; height: 16px; }

  /* Related */
  .related-section {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }
  .related-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 20px;
    color: var(--color-text);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 20px;
  }
  .related-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .related-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-border-strong);
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  }
  .related-img {
    width: 100%;
    height: 140px;
    object-fit: cover;
  }
  .related-info {
    padding: 14px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .related-card-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }
  .related-date {
    font-size: 0.75rem;
    color: var(--color-text-dim);
  }

  /* Toast */
  .toast-container { position: fixed; top: 24px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; }
  .toast { padding: 12px 20px; border-radius: var(--radius-md); font-size: 0.85rem; font-weight: 500; color: #fff; opacity: 0; transform: translateX(20px); transition: all 0.3s ease; box-shadow: 0 10px 40px rgba(0,0,0,0.3); }
  .toast.show { opacity: 1; transform: translateX(0); }
  .toast-success { background: #16a34a; }
  .toast-error { background: #dc2626; }

  @media (max-width: 768px) {
    .article-hero { min-height: 280px; padding: 32px 16px; }
    .article-body { padding: 28px 16px 60px; }
    .related-grid { grid-template-columns: 1fr; }
    .summary-card { flex-direction: column; gap: 10px; }
  }
</style>
