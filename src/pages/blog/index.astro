---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="ZeroFX Trading Videos & Articles - Gold, Forex & Crypto Analysis">
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href="https://zerofx.com/blog" />
    <link rel="alternate" hreflang="ar" href="https://zerofx.com/ar/blog" />
    <link rel="alternate" hreflang="fr" href="https://zerofx.com/fr/blog" />
    <script type="application/ld+json" id="video-schema">
      {
        "@context": "https://schema.org",
        "@type": "ItemList",
        "itemListElement": []
      }
    </script>
    <meta property="og:title" content="ZeroFX Trading Videos & Articles" id="og-title" />
    <meta property="og:description" content="Read and watch ZeroFX trading articles and videos on Gold, Crypto, Forex and US Indices." id="og-desc" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://img.youtube.com/vi/FvIj7Y6OgOo/maxresdefault.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
  </Fragment>

  <Navbar />

  <main class="blog-page">
    <!-- Header Section -->
    <section class="blog-hero">
      <div class="hero-glow"></div>
      <div class="blog-hero-inner">
        <h1 class="blog-title" data-i18n="blog.title">Trading Videos & Market Analysis</h1>
        <p class="blog-subtitle" data-i18n="blog.desc">Watch our latest updates on Gold, US Indices, Crypto, and Forex.</p>
        <a href="https://www.youtube.com/@zerowfx1" target="_blank" rel="noopener noreferrer" class="youtube-btn">
          <i data-lucide="youtube" style="width:20px;height:20px;"></i>
          <span data-i18n="blog.subscribe">Subscribe on YouTube</span>
        </a>
      </div>
    </section>

    <!-- Tab Bar + Search -->
    <div class="tab-bar-wrapper">
      <div class="tab-bar">
        <div class="tab-group">
          <button class="tab-btn active" id="tab-videos" data-tab="videos" aria-selected="true">
            <i data-lucide="play-circle" style="width:16px;height:16px;"></i>
            <span data-i18n="blog.tab.videos">Videos</span>
          </button>
          <button class="tab-btn" id="tab-live" data-tab="live" aria-selected="false">
            <span class="live-dot"></span>
            <span data-i18n="blog.tab.live">Live</span>
          </button>
        </div>
        <div class="search-box" id="search-box" role="search">
          <i data-lucide="search" style="width:16px;height:16px;" class="search-icon"></i>
          <input
            type="search"
            id="blog-search"
            class="search-input"
            placeholder="Search videos..."
            data-i18n-placeholder="blog.search.placeholder"
            aria-label="Search videos"
            autocomplete="off"
          />
          <button class="search-clear" id="search-clear" aria-label="Clear search" style="display:none;">
            <i data-lucide="x" style="width:14px;height:14px;"></i>
          </button>
        </div>
      </div>
      <div class="tab-underline"></div>
    </div>

    <!-- Videos Panel -->
    <section class="panel-videos articles-section" id="panel-videos">
      <!-- No Results -->
      <div class="no-results" id="no-results" style="display:none;">
        <i data-lucide="video-off" style="width:48px;height:48px;opacity:0.3;"></i>
        <p data-i18n="blog.search.noresults">No videos found. Try a different search.</p>
      </div>

      <div class="articles-container" id="articles-container">
        <!-- Article 1 -->
        <article class="blog-article" id="article-vid1"
          data-title="1st Place Winner Among 8,000 Traders in XM Morocco Championship"
          data-desc="An inspiring journey of winning 1st place among 8,000 traders in the XM Morocco Trading Championship. We share the strategies, patience, and mindset that led to this remarkable achievement."
          data-tags="#Trading #XM #Forex #Morocco #Championship">
          <h2 class="article-title" data-i18n="blog.vid1.title">1st Place Winner Among 8,000 Traders in XM Morocco Championship</h2>
          <div class="article-content">
            <p data-i18n="blog.vid1.article">An inspiring journey of winning 1st place among 8,000 traders in the XM Morocco Trading Championship. We share the strategies, patience, and mindset that led to this remarkable achievement.</p>
          </div>
          <div class="video-container">
            <iframe src="https://www.youtube.com/embed/FvIj7Y6OgOo" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
          </div>
          <div class="article-tags" data-i18n="blog.vid1.tags">#Trading #XM #Forex #Morocco #Championship</div>
        </article>

        <!-- Article 2 -->
        <article class="blog-article" id="article-vid2"
          data-title="Most Important Markets in 2026 & Quick Fundamentals Guide"
          data-desc="Discover the most important markets to trade in 2026. This video provides a quick and effective explanation of fundamental analysis in trading, covering key economic indicators and market trends."
          data-tags="#Trading2026 #Fundamentals #Forex #Investing">
