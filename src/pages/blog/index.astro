<script is:inline>
document.addEventListener('DOMContentLoaded', () => {

  // ── Tab Switching ──────────────────────────────────────────────────────────
  const tabBtns  = document.querySelectorAll('.tab-btn');
  const panelVideos = document.getElementById('panel-videos');
  const panelLive   = document.getElementById('panel-live');
  const searchBox   = document.getElementById('search-box');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab;

      tabBtns.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');

      if (tab === 'videos') {
        panelVideos.style.display = '';
        panelLive.style.display   = 'none';
        searchBox.style.display   = '';
      } else {
        panelVideos.style.display = 'none';
        panelLive.style.display   = '';
        searchBox.style.display   = 'none';
      }
    });
  });

  // ── Search ────────────────────────────────────────────────────────────────
  const searchInput = document.getElementById('blog-search');
  const clearBtn    = document.getElementById('search-clear');
  const noResults   = document.getElementById('no-results');
  const articles    = document.querySelectorAll('.blog-article');

  function doSearch(query) {
    const q = query.trim().toLowerCase();
    let visibleCount = 0;

    articles.forEach(article => {
      const title = (article.dataset.title || '').toLowerCase();
      const desc  = (article.dataset.desc  || '').toLowerCase();
      const tags  = (article.dataset.tags  || '').toLowerCase();
      // Also search translated text currently rendered
      const renderedTitle = (article.querySelector('.article-title')?.textContent || '').toLowerCase();
      const renderedDesc  = (article.querySelector('.article-content')?.textContent || '').toLowerCase();
      const renderedTags  = (article.querySelector('.article-tags')?.textContent   || '').toLowerCase();

      const matches = !q ||
        title.includes(q) || desc.includes(q) || tags.includes(q) ||
        renderedTitle.includes(q) || renderedDesc.includes(q) || renderedTags.includes(q);

      article.style.display = matches ? '' : 'none';
      if (matches) visibleCount++;
    });

    noResults.style.display = visibleCount === 0 ? 'flex' : 'none';
    clearBtn.style.display  = q ? 'flex' : 'none';
  }

  searchInput.addEventListener('input', e => doSearch(e.target.value));

  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    doSearch('');
    searchInput.focus();
  });

  // ── Multi-language SEO ────────────────────────────────────────────────────
  function updateBlogSEO() {
    const lang = window.currentLang || 'en';
    const titles = {
      en: "ZeroFX Trading Videos & Articles - Gold, Forex & Crypto Analysis",
      ar: "مقالات وفيديوهات تداول ZeroFX - تحليل الذهب والفوركس والعملات الرقمية",
      fr: "Vidéos et Articles de Trading ZeroFX - Analyse Or, Forex & Crypto"
    };
    const descs = {
      en: "Watch and read ZeroFX trading articles and videos on Gold, Crypto, Forex and US Indices.",
      ar: "شاهد واقرأ مقالات وفيديوهات تداول ZeroFX حول الذهب والعملات الرقمية والفوركس ومؤشرات السوق الأمريكية.",
      fr: "Lisez et regardez les articles et vidéos de trading ZeroFX sur l'Or, la Crypto, le Forex et les Indices US."
    };
    const placeholders = {
      en: "Search videos...",
      ar: "ابحث عن فيديوهات...",
      fr: "Rechercher des vidéos..."
    };

    document.title = titles[lang] || titles.en;
    setTimeout(() => { document.title = titles[lang] || titles.en; }, 50);

    const metaDesc = document.querySelector('meta[name="description"]');
    if (metaDesc) metaDesc.setAttribute('content', descs[lang] || descs.en);

    const ogTitle = document.getElementById('og-title');
    if (ogTitle) ogTitle.setAttribute('content', titles[lang] || titles.en);

    const ogDesc = document.getElementById('og-desc');
    if (ogDesc) ogDesc.setAttribute('content', descs[lang] || descs.en);

    if (searchInput) searchInput.setAttribute('placeholder', placeholders[lang] || placeholders.en);

    generateSchema();
  }

  window.addEventListener('languageChanged', updateBlogSEO);

  const originalApplyTranslations = window.applyTranslations;
  if (originalApplyTranslations) {
    window.applyTranslations = function() {
      originalApplyTranslations();
      updateBlogSEO();
    };
    updateBlogSEO();
  } else {
    updateBlogSEO();
  }

  function generateSchema() {
    const lang = window.currentLang || 'en';
    const schemaEl = document.getElementById('video-schema');
    if (!schemaEl) return;

    const videos = [
       { id: "FvIj7Y6OgOo", key: "vid1" },
       { id: "PJzcUsbD-d4", key: "vid2" },
       { id: "qkAXCxVWp3I", key: "vid3" },
       { id: "GliF_2oY850", key: "vid4" },
       { id: "sIzDtkp-6LQ", key: "vid5" },
       { id: "vkAfQrAN5qg", key: "vid6" }
    ];

    const items = videos.map((video, idx) => {
      let title = "";
      let desc  = "";
      if (window.i18nData && window.i18nData[lang]) {
         title = window.i18nData[lang][`blog.${video.key}.title`] || "";
         desc  = window.i18nData[lang][`blog.${video.key}.article`] || "";
      }
      return {
        "@type": "ListItem",
        "position": idx + 1,
        "item": {
          "@type": "VideoObject",
          "name": title,
          "description": desc,
          "thumbnailUrl": `https://img.youtube.com/vi/${video.id}/maxresdefault.jpg`,
          "uploadDate": "2026-01-01T00:00:00Z",
          "contentUrl": `https://www.youtube.com/watch?v=${video.id}`,
          "embedUrl": `https://www.youtube.com/embed/${video.id}`,
          "inLanguage": lang
        }
      };
    });

    schemaEl.textContent = JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "itemListElement": items
    });
  }

  if (window.lucide) window.lucide.createIcons();
});
</script>

<style>
  /* ── General Page Styles ── */
  .blog-page {
    padding-top: 64px;
    min-height: 100vh;
  }

  /* ── Hero ── */
  .blog-hero {
    position: relative;
    padding: 80px 24px 60px;
    text-align: center;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-glow {
    position: absolute;
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, var(--color-green-glow) 0%, transparent 70%);
    pointer-events: none;
    opacity: 0.6;
  }

  .blog-hero-inner {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .blog-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.5px;
    margin-bottom: 16px;
    color: var(--color-text);
  }

  .blog-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .youtube-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #ff0000;
    color: #fff;
    padding: 12px 24px;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 1rem;
    transition: var(--transition);
  }

  .youtube-btn:hover {
    background: #cc0000;
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(255, 0, 0, 0.3);
  }

  /* ── Tab Bar ── */
  .tab-bar-wrapper {
    position: sticky;
    top: 64px;
    z-index: 40;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .tab-bar {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 0;
    justify-content: space-between;
  }

  .tab-group {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 16px 20px 14px;
    font-size: 0.95rem;
