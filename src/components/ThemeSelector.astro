---
---
<button class="theme-switch" id="themeSwitch" aria-label="Toggle dark/light mode" type="button">
  <span class="switch-track">
    <!-- Sun icon -->
    <svg class="switch-icon sun-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="5"/>
      <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
    </svg>
    <!-- Moon icon -->
    <svg class="switch-icon moon-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
    <span class="switch-thumb"></span>
  </span>
</button>

<script>
  const themeSwitch = document.getElementById('themeSwitch');
  const html = document.documentElement;

  // Load saved theme
  const savedTheme = localStorage.getItem('zerowfx-theme') || 'emerald-night';
  applyTheme(savedTheme);

  // Toggle on click
  themeSwitch?.addEventListener('click', () => {
    const currentTheme = localStorage.getItem('zerowfx-theme') || 'emerald-night';
    const newTheme = currentTheme === 'emerald-night' ? 'clean-white' : 'emerald-night';
    applyTheme(newTheme);
    localStorage.setItem('zerowfx-theme', newTheme);
  });

  function applyTheme(theme: string) {
    // Remove all theme classes
    html.className = html.className.replace(/theme-\S+/g, '').trim();
    // Add new theme class
    if (theme !== 'emerald-night') {
      html.classList.add(`theme-${theme}`);
    }

    // Toggle switch visual state
    const isLight = theme === 'clean-white';
    themeSwitch?.classList.toggle('is-light', isLight);
  }
</script>

<style>
  /* ===== Theme Toggle Switch ===== */
  .theme-switch {
    position: relative;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .switch-track {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 52px;
    height: 28px;
    padding: 0 6px;
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-sizing: border-box;
  }

  .theme-switch:hover .switch-track {
    border-color: var(--color-green);
    box-shadow: 0 0 12px rgba(34, 197, 94, 0.2);
  }

  /* Thumb (the sliding circle) */
  .switch-thumb {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #e2e8f0;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Icons */
  .switch-icon {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Default state = DARK mode: moon visible, sun dimmed, thumb LEFT */
  .sun-icon {
    opacity: 0.3;
    color: #9ca3af;
  }

  .moon-icon {
    opacity: 1;
    color: #e2e8f0;
  }

  /* LIGHT mode: sun visible, moon dimmed, thumb RIGHT */
  .theme-switch.is-light .switch-track {
    background: rgba(0, 0, 0, 0.06);
    border-color: rgba(0, 0, 0, 0.12);
  }

  .theme-switch.is-light:hover .switch-track {
    border-color: #10b981;
    box-shadow: 0 0 12px rgba(16, 185, 129, 0.2);
  }

  .theme-switch.is-light .switch-thumb {
    left: calc(100% - 23px);
    background: #fbbf24;
    box-shadow: 0 0 8px rgba(251, 191, 36, 0.4), 0 1px 4px rgba(0, 0, 0, 0.15);
  }

  .theme-switch.is-light .sun-icon {
    opacity: 1;
    color: #111827;
  }

  .theme-switch.is-light .moon-icon {
    opacity: 0.3;
    color: #9ca3af;
  }

  /* Active press feedback */
  .theme-switch:active .switch-thumb {
    width: 24px;
  }

  .theme-switch.is-light:active .switch-thumb {
    left: calc(100% - 27px);
  }

  /* Mobile — same size, works great on touch */
  @media (max-width: 768px) {
    .switch-track {
      width: 48px;
      height: 26px;
    }

    .switch-thumb {
      width: 18px;
      height: 18px;
      top: 3px;
      left: 3px;
    }

    .theme-switch.is-light .switch-thumb {
      left: calc(100% - 21px);
    }

    .theme-switch:active .switch-thumb {
      width: 22px;
    }

    .theme-switch.is-light:active .switch-thumb {
      left: calc(100% - 25px);
    }

    .switch-icon {
      width: 12px;
      height: 12px;
    }
  }
</style>
