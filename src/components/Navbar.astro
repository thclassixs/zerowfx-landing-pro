---
import ThemeSelector from './ThemeSelector.astro';
---
<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="/logo.webp" alt="Zerowfx" class="logo-img" />
      <span class="logo-text">ZERO<span class="logo-accent">WFX</span></span>
    </a>

    <div class="nav-links" id="navLinks">
      <a href="/" class="nav-link" data-i18n="nav.about" onclick="if(window.location.pathname==='/'||window.location.pathname==='/index.html'){window.scrollTo({top:0,behavior:'smooth'});return false;}">Home</a>
      <a href="/#setups" class="nav-link" data-i18n="nav.setups">Setups</a>
      <a href="/#results" class="nav-link" data-i18n="nav.results">Results</a>
      <a href="/#partners" class="nav-link" data-i18n="nav.partners">Partners</a>
      <a href="/charts" class="nav-link" data-i18n="nav.charts">Charts</a>
      <a href="/blog" class="nav-link" data-i18n="nav.blogs">Blogs</a>
      <div class="nav-dropdown" id="toolsDropdown">
        <button class="nav-link dropdown-trigger">
          <span data-i18n="nav.tools">Tools</span> <i data-lucide="chevron-down" style="width:14px;height:14px;display:inline-block;vertical-align:middle;margin-left:2px;"></i>
        </button>
        <div class="dropdown-panel">
          <div class="dropdown-grid">
            <a href="/tools/pip-calculator" class="dropdown-item"><i data-lucide="trending-up"></i><span data-i18n="tools.pip-calculator.name">Pip Calculator</span></a>
            <a href="/tools/pip-value-calculator" class="dropdown-item"><i data-lucide="dollar-sign"></i><span data-i18n="tools.pip-value-calculator.name">Pip Value Calculator</span></a>
            <a href="/tools/lot-size-calculator" class="dropdown-item"><i data-lucide="layers"></i><span data-i18n="tools.lot-size-calculator.name">Lot Size Calculator</span></a>
            <a href="/tools/margin-calculator" class="dropdown-item"><i data-lucide="lock"></i><span data-i18n="tools.margin-calculator.name">Margin Calculator</span></a>
            <a href="/tools/position-size-calculator" class="dropdown-item"><i data-lucide="target"></i><span data-i18n="tools.position-size-calculator.name">Position Size Calculator</span></a>
            <a href="/tools/profit-calculator" class="dropdown-item"><i data-lucide="badge-dollar-sign"></i><span data-i18n="tools.profit-calculator.name">Profit Calculator</span></a>
            <a href="/tools/risk-calculator" class="dropdown-item"><i data-lucide="shield-alert"></i><span data-i18n="tools.risk-calculator.name">Risk Calculator</span></a>
            <a href="/tools/sl-tp-calculator" class="dropdown-item"><i data-lucide="arrow-down-up"></i><span data-i18n="tools.sl-tp-calculator.name">SL &amp; TP Calculator</span></a>
            <a href="/tools/spread-calculator" class="dropdown-item"><i data-lucide="arrow-left-right"></i><span data-i18n="tools.spread-calculator.name">Spread Cost Calculator</span></a>
            <a href="/tools/swap-calculator" class="dropdown-item"><i data-lucide="repeat"></i><span data-i18n="tools.swap-calculator.name">Swap Calculator</span></a>
            <a href="/tools/drawdown-calculator" class="dropdown-item"><i data-lucide="trending-down"></i><span data-i18n="tools.drawdown-calculator.name">Drawdown Calculator</span></a>
            <a href="/tools/fibonacci-calculator" class="dropdown-item"><i data-lucide="git-branch"></i><span data-i18n="tools.fibonacci-calculator.name">Fibonacci Calculator</span></a>
            <a href="/tools/pivot-points-calculator" class="dropdown-item"><i data-lucide="navigation"></i><span data-i18n="tools.pivot-points-calculator.name">Pivot Points Calculator</span></a>
            <a href="/tools/leverage-calculator" class="dropdown-item"><i data-lucide="zap"></i><span data-i18n="tools.leverage-calculator.name">Leverage Calculator</span></a>
            <a href="/tools/commission-calculator" class="dropdown-item"><i data-lucide="receipt"></i><span data-i18n="tools.commission-calculator.name">Commission Calculator</span></a>
            <a href="/tools/zero-strategy-calculator" class="dropdown-item"><i data-lucide="line-chart"></i><span data-i18n="tools.zero-strategy-calculator.name">ZEROWFX-Strategy Calculator</span></a>
          </div>
        </div>
      </div>

    </div>

    <div class="nav-right">
      <ThemeSelector />
      
      <!-- Language Dropdown -->
      <div class="nav-dropdown" id="langDropdown">
        <button class="lang-toggle dropdown-trigger" id="langToggleBtn">
          <i data-lucide="globe" style="width:16px;height:16px;"></i>
          <span class="lang-code" id="activeLangText">EN</span>
          <i data-lucide="chevron-down" style="width:12px;height:12px;margin-left:2px;"></i>
        </button>
        <div class="dropdown-panel lang-panel">
          <button class="lang-option" data-lang="en">
            <span class="lang-flag">🇬🇧</span> English
          </button>
          <button class="lang-option" data-lang="ar">
            <span class="lang-flag">🇸🇦</span> العربية
          </button>
          <button class="lang-option" data-lang="fr">
            <span class="lang-flag">🇫🇷</span> Français
          </button>
        </div>
      </div>

      <button class="hamburger" id="hamburger" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="/" class="mobile-link" data-i18n="nav.about" onclick="if(window.location.pathname==='/'||window.location.pathname==='/index.html'){window.scrollTo({top:0,behavior:'smooth'});return false;}">Home</a>
    <a href="/#setups" class="mobile-link" data-i18n="nav.setups">Setups</a>
    <a href="/#results" class="mobile-link" data-i18n="nav.results">Results</a>
    <a href="/#partners" class="mobile-link" data-i18n="nav.partners">Partners</a>
    <a href="/charts" class="mobile-link" data-i18n="nav.charts">Charts</a>
    <a href="/blog" class="mobile-link" data-i18n="nav.blogs">Blogs</a>
    <button class="mobile-link mobile-tools-toggle" id="mobileToolsToggle">
      <span data-i18n="nav.tools">Tools</span> <i data-lucide="chevron-down" style="width:14px;height:14px;display:inline-block;vertical-align:middle;margin-left:4px;transition:transform 0.3s;"></i>
    </button>
    <div class="mobile-tools-list" id="mobileToolsList">
      <a href="/tools/pip-calculator" class="mobile-tool-link" data-i18n="tools.pip-calculator.name">Pip Calculator</a>
      <a href="/tools/pip-value-calculator" class="mobile-tool-link" data-i18n="tools.pip-value-calculator.name">Pip Value Calculator</a>
      <a href="/tools/lot-size-calculator" class="mobile-tool-link" data-i18n="tools.lot-size-calculator.name">Lot Size Calculator</a>
      <a href="/tools/margin-calculator" class="mobile-tool-link" data-i18n="tools.margin-calculator.name">Margin Calculator</a>
      <a href="/tools/position-size-calculator" class="mobile-tool-link" data-i18n="tools.position-size-calculator.name">Position Size Calculator</a>
      <a href="/tools/profit-calculator" class="mobile-tool-link" data-i18n="tools.profit-calculator.name">Profit Calculator</a>
      <a href="/tools/risk-calculator" class="mobile-tool-link" data-i18n="tools.risk-calculator.name">Risk Calculator</a>
      <a href="/tools/sl-tp-calculator" class="mobile-tool-link" data-i18n="tools.sl-tp-calculator.name">SL &amp; TP Calculator</a>
      <a href="/tools/spread-calculator" class="mobile-tool-link" data-i18n="tools.spread-calculator.name">Spread Cost Calculator</a>
      <a href="/tools/swap-calculator" class="mobile-tool-link" data-i18n="tools.swap-calculator.name">Swap Calculator</a>
      <a href="/tools/drawdown-calculator" class="mobile-tool-link" data-i18n="tools.drawdown-calculator.name">Drawdown Calculator</a>
      <a href="/tools/fibonacci-calculator" class="mobile-tool-link" data-i18n="tools.fibonacci-calculator.name">Fibonacci Calculator</a>
      <a href="/tools/pivot-points-calculator" class="mobile-tool-link" data-i18n="tools.pivot-points-calculator.name">Pivot Points Calculator</a>
      <a href="/tools/leverage-calculator" class="mobile-tool-link" data-i18n="tools.leverage-calculator.name">Leverage Calculator</a>
      <a href="/tools/commission-calculator" class="mobile-tool-link" data-i18n="tools.commission-calculator.name">Commission Calculator</a>
      <a href="/tools/zero-strategy-calculator" class="mobile-tool-link" data-i18n="tools.zero-strategy-calculator.name">ZEROWFX-Strategy Calculator</a>
    </div>
  </div>
</nav>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  const navbar = document.getElementById('navbar');

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('active');
    mobileMenu?.classList.toggle('open');
  });

  // Close menu on link click
  document.querySelectorAll('.mobile-link:not(.mobile-tools-toggle)').forEach(link => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('active');
      mobileMenu?.classList.remove('open');
    });
  });

  // Mobile tools toggle
  const mobileToolsToggle = document.getElementById('mobileToolsToggle');
  const mobileToolsList = document.getElementById('mobileToolsList');
  mobileToolsToggle?.addEventListener('click', () => {
    mobileToolsList?.classList.toggle('open');
    mobileToolsToggle.classList.toggle('expanded');
  });

  // Close mobile menu on tool link click
  document.querySelectorAll('.mobile-tool-link').forEach(link => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('active');
      mobileMenu?.classList.remove('open');
    });
  });

  // Language Selection Logic
  const validLangs = ['en', 'ar', 'fr'];
  let currentLang = localStorage.getItem('language') || 'en';
  if (!validLangs.includes(currentLang)) currentLang = 'en';

  const activeLangText = document.getElementById('activeLangText');
  if (activeLangText) {
    activeLangText.textContent = currentLang.toUpperCase();
  }

  const langOptions = document.querySelectorAll('.lang-option');
  langOptions.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const selectedLang = (e.currentTarget as HTMLElement).getAttribute('data-lang');
      if (selectedLang && validLangs.includes(selectedLang)) {
        localStorage.setItem('language', selectedLang);
        window.location.reload();
      }
    });
  });

  // Navbar scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(8, 9, 11, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border);
    transition: var(--transition);
  }
  .navbar.scrolled {
    background: rgba(8, 9, 11, 0.95);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
  }
  .nav-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .logo-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-green);
  }
  .logo-text {
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #fff;
  }
  .logo-accent {
    color: var(--color-green);
  }
  .nav-links {
    display: flex;
    gap: 32px;
    align-items: center;
  }
  .nav-link {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: var(--transition);
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    padding: 0;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-green);
    transition: var(--transition);
  }
  .nav-link:hover {
    color: var(--color-green-light);
  }
  .nav-link:hover::after {
    width: 100%;
  }

  /* Tools Dropdown */
  .nav-dropdown {
    position: relative;
  }
  .dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 2px;
  }
  .dropdown-panel {
    position: absolute;
    top: calc(100% + 16px);
    left: 50%;
    transform: translateX(-50%);
    width: 520px;
    background: rgba(20, 22, 24, 0.97);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    padding: 12px;
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(8px);
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    z-index: 1001;
  }
  .dropdown-panel::before {
    content: '';
    position: absolute;
    top: -12px;
    left: 0;
    right: 0;
    height: 12px;
  }
  .nav-dropdown:hover .dropdown-panel {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .dropdown-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }
  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    transition: var(--transition);
    white-space: nowrap;
  }
  .dropdown-item i, .dropdown-item svg {
    width: 15px;
    height: 15px;
    color: var(--color-green);
    flex-shrink: 0;
  }
  .dropdown-item:hover {
    background: var(--color-bg-elevated);
    color: var(--color-green-light);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  /* Language Dropdown Customizations */
  .lang-panel {
    width: 160px;
    padding: 8px;
    left: auto;
    right: 0;
    transform: translateX(0) translateY(8px);
  }
  .nav-dropdown:hover .lang-panel {
    transform: translateX(0) translateY(0);
  }
  html[dir="rtl"] .lang-panel {
    right: auto;
    left: 0;
  }

  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    transition: var(--transition);
    background: transparent;
    font-family: inherit;
  }
  .lang-toggle:hover {
    border-color: var(--color-green);
    color: var(--color-text);
  }
  .lang-option {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    text-align: left;
    background: transparent;
    border: none;
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-size: 0.9rem;
    cursor: pointer;
    transition: var(--transition);
    font-family: inherit;
  }
  html[dir="rtl"] .lang-option {
    text-align: right;
  }
  .lang-option:hover {
    background: var(--color-bg-elevated);
    color: var(--color-green);
  }
  .lang-flag {
    font-size: 1.1rem;
  }
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    padding: 4px;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: var(--transition);
  }
  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }
  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }
  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 0 24px 20px;
    gap: 4px;
    max-height: calc(100dvh - 64px);
    overflow-y: auto;
  }
  .mobile-menu.open {
    display: flex;
  }
  .mobile-link {
    padding: 12px 16px;
    color: var(--color-text-muted);
    font-weight: 500;
    border-radius: var(--radius-sm);
    transition: var(--transition);
    background: none;
    border: none;
    font-family: inherit;
    font-size: inherit;
    cursor: pointer;
    text-align: left;
    width: 100%;
  }
  .mobile-link:hover {
    background: var(--color-bg-elevated);
    color: var(--color-green-light);
  }
  .mobile-tools-toggle {
    display: flex;
    align-items: center;
  }
  .mobile-tools-toggle.expanded i,
  .mobile-tools-toggle.expanded svg {
    transform: rotate(180deg);
  }
  .mobile-tools-list {
    display: none;
    flex-direction: column;
    gap: 2px;
    padding-left: 16px;
    margin-top: 2px;
    border-left: 2px solid var(--color-border-strong);
    margin-left: 16px;
  }
  .mobile-tools-list.open {
    display: flex;
  }
  .mobile-tool-link {
    padding: 8px 14px;
    color: var(--color-text-dim);
    font-size: 0.88rem;
    font-weight: 500;
    border-radius: var(--radius-sm);
    transition: var(--transition);
  }
  .mobile-tool-link:hover {
    background: var(--color-bg-elevated);
    color: var(--color-green-light);
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
    .hamburger {
      display: flex;
    }
    .lang-toggle .lang-code {
      display: none;
    }
  }
</style>
