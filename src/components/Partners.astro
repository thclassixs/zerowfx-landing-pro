---
---
<section class="partners" id="partners">
  <div class="partners-inner">
    <div class="partners-badge" data-i18n="partners.badge">RECOMMENDED BROKER</div>

    <h2 class="partners-title">
      <span data-i18n="partners.title1">Start Trading with </span><em class="partners-accent" data-i18n="partners.title2">100% Bonus</em>
    </h2>

    <p class="partners-desc" data-i18n="partners.desc">
      Get a 100% deposit bonus when you sign up with XM - our trusted broker
      partner. Trade gold, forex, and indices with tight spreads and fast execution.
    </p>

    <div class="partners-features">
      <div class="partners-feature">
        <i data-lucide="check" class="feature-check-icon"></i>
        <span data-i18n="partners.feat1">100% Deposit Bonus</span>
      </div>
      <div class="partners-feature">
        <i data-lucide="check" class="feature-check-icon"></i>
        <span data-i18n="partners.feat2">Tight Spreads on Gold</span>
      </div>
      <div class="partners-feature">
        <i data-lucide="check" class="feature-check-icon"></i>
        <span data-i18n="partners.feat3">Fast Withdrawals</span>
      </div>
    </div>

    <a
      href="https://affs.click/X3LJB"
      target="_blank"
      rel="noopener"
      class="partners-cta"
    >
      <span data-i18n="partners.cta">CLAIM YOUR 100% BONUS</span> <i data-lucide="arrow-right" style="width:18px;height:18px;display:inline;vertical-align:middle"></i>
    </a>

    <p class="partners-disclaimer">
      <span data-i18n="partners.disclaimer">Trading involves risk. Partner code:</span> <strong>CQMHK</strong>
    </p>
  </div>
</section>

<style>
  .partners {
    padding: 80px 24px;
    background: var(--color-bg);
    text-align: center;
    border-top: 1px solid var(--color-border);
  }
  .partners-inner {
    max-width: 700px;
    margin: 0 auto;
  }
  .partners-badge {
    display: inline-block;
    padding: 6px 20px;
    border: 1px solid var(--color-green);
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--color-green);
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .partners-title {
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 16px;
  }
  .partners-accent {
    background: linear-gradient(135deg, var(--color-green), var(--color-green-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }
  .partners-desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 28px;
  }
  .partners-features {
    display: flex;
    justify-content: center;
    gap: 32px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .partners-feature {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
  .feature-check-icon {
    color: var(--color-green);
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .partners-cta {
    display: inline-block;
    padding: 16px 48px;
    background: linear-gradient(135deg, var(--color-green-dark), var(--color-green));
    color: #fff;
    font-weight: 800;
    font-size: 1.05rem;
    border-radius: var(--radius-md);
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: var(--transition);
    box-shadow: 0 4px 20px rgba(34, 197, 94, 0.3);
    margin-bottom: 16px;
  }
  .partners-cta:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow-strong);
  }
  .partners-disclaimer {
    color: var(--color-text-dim);
    font-size: 0.8rem;
  }

  @media (max-width: 480px) {
    .partners {
      padding: 60px 16px;
    }
    .partners-features {
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
  }
</style>
