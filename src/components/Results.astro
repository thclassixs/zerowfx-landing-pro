---
// Member results gallery - screenshots from followers showing their results
const images = Array.from({ length: 30 }, (_, i) => ({
  src: `/assets/results/a${i + 1}.webp`,
}));
---

<section class="results" id="results">
  <div class="results-inner">
    <h2 class="section-title" data-i18n="results.title">Member Results</h2>
    <p class="section-subtitle" data-i18n="results.subtitle">Real results from real members following our strategies</p>

    <div class="results-grid-wrapper">
      <div class="results-scroll" id="resultsScroll">
        <div class="results-track" id="resultsTrack">
          {images.map((img, i) => (
            <div class="results-item">
              <img src={img.src} alt={`Member result ${i + 1}`} decoding="async" />
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ZERO Strategy Tool CTA -->
    <div class="cot-cta-wrapper">
      <p class="cot-cta-text" data-i18n="results.ctatext">Want to simulate your own trading performance?</p>
      <a href="/tools/zero-strategy-calculator" class="cot-cta-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="20" x2="18" y2="10"></line>
          <line x1="12" y1="20" x2="12" y2="4"></line>
          <line x1="6" y1="20" x2="6" y2="14"></line>
        </svg>
        <span data-i18n="results.ctabtn">Try ZEROWFX-Strategy Calculator</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="cot-arrow">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .results {
    padding: 80px 24px;
    background: var(--color-bg);
    text-align: center;
    overflow: hidden;
  }
  .results-inner {
    max-width: 1560px;
    margin: 0 auto;
  }
  .section-title {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 800;
    margin-bottom: 10px;
  }
  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 40px;
  }
  .results-grid-wrapper {
    position: relative;
  }
  .results-scroll {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, black 5%, black 95%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, black 5%, black 95%, transparent);
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }
  .results-track {
    display: flex;
    gap: 16px;
    animation: resultsScroll 60s linear infinite;
    width: max-content;
    will-change: transform;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }
  .results-item {
    flex: 0 0 220px;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: var(--transition);
  }
  .results-item:hover {
    border-color: var(--color-green);
    transform: scale(1.03);
    box-shadow: var(--shadow-glow);
  }
  .results-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  html[dir="rtl"] .results-track {
    animation: resultsScrollRtl 60s linear infinite;
  }

  @keyframes resultsScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes resultsScrollRtl {
    0% { transform: translateX(0); }
    100% { transform: translateX(50%); }
  }

  /* ZERO Strategy CTA */
  .cot-cta-wrapper {
    margin-top: 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .cot-cta-text {
    color: var(--color-text-muted);
    font-size: 1rem;
    font-weight: 500;
  }
  .cot-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    background: linear-gradient(135deg, var(--color-green-dark), var(--color-green));
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    border-radius: var(--radius-md);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 24px rgba(34, 197, 94, 0.25);
    text-decoration: none;
  }
  .cot-cta-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(34, 197, 94, 0.4);
  }
  .cot-cta-btn:active {
    transform: translateY(-1px);
  }
  .cot-arrow {
    transition: transform 0.3s ease;
  }
  .cot-cta-btn:hover .cot-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 480px) {
    .results {
      padding: 60px 16px;
    }
    .results-item {
      flex: 0 0 180px;
    }
    .cot-cta-btn {
      padding: 14px 24px;
      font-size: 0.9rem;
    }
  }
</style>