---
import '../styles/themes.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title = 'Zerowfx - Master Forex Trading',
  description = 'Master the Forex markets with proven strategies and expert mentorship. Join hundreds of successful traders who have transformed their trading journey with Zerowfx.',
  canonical,
  noindex = false
} = Astro.props;

const siteUrl = 'https://zerowfx.com';
const canonicalURL = canonical || new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <title>{title}</title>
    <slot name="head" />
    <!-- i18n Data -->
    <script src="/i18n.js?v=4" is:inline></script>
    <!-- Apply saved theme and language immediately to prevent FOUC -->
    <script is:inline>
      (function() {
        var valid = ['emerald-night','clean-white'];
        var saved = localStorage.getItem('zerowfx-theme');
        if (!saved || valid.indexOf(saved) === -1) {
          saved = 'emerald-night';
          localStorage.setItem('zerowfx-theme', 'emerald-night');
        }
        if (saved !== 'emerald-night') {
          document.documentElement.classList.add('theme-' + saved);
        }

        var savedLang = localStorage.getItem('language') || 'en';
        var validLangs = ['en', 'ar', 'fr'];
        if (validLangs.indexOf(savedLang) === -1) savedLang = 'en';
        
        document.documentElement.lang = savedLang;
        document.documentElement.dir = savedLang === 'ar' ? 'rtl' : 'ltr';
        window.currentLang = savedLang;
      })();
    </script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MN651XN208"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-MN651XN208');
    </script>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </head>
  <body>
    <slot />
    <script is:inline>
      // Initialize Lucide icons after DOM is ready
      document.addEventListener('DOMContentLoaded', () => {
        if (window.lucide) window.lucide.createIcons();
      });

      // Apply translations instantly
      (function() {
        window.applyTranslations = function applyTranslations() {
          const lang = window.currentLang || 'en';
          const texts = document.querySelectorAll('[data-i18n]');
          texts.forEach(el => {
            const key = el.getAttribute('data-i18n');
            if (window.i18nData && window.i18nData[lang] && window.i18nData[lang][key]) {
              el.innerHTML = window.i18nData[lang][key];
            }
          });
          const placeholders = document.querySelectorAll('[data-i18n-placeholder]');
          placeholders.forEach(el => {
            const key = el.getAttribute('data-i18n-placeholder');
            if (window.i18nData && window.i18nData[lang] && window.i18nData[lang][key]) {
              el.setAttribute('placeholder', window.i18nData[lang][key]);
            }
          });
          
          if (window.i18nData && window.i18nData[lang]) {
            if (window.i18nData[lang]['meta.title']) {
              document.title = window.i18nData[lang]['meta.title'];
            }
            const descMeta = document.querySelector('meta[name="description"]');
            if (descMeta && window.i18nData[lang]['meta.desc']) {
              descMeta.setAttribute('content', window.i18nData[lang]['meta.desc']);
            }
          }
        };
        window.applyTranslations();
      })();
    </script>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --color-bg: #08090b;
    --color-bg-secondary: #0f1114;
    --color-bg-card: #141618;
    --color-bg-elevated: #1a1d21;
    --color-green: #22c55e;
    --color-green-light: #4ade80;
    --color-green-dark: #16a34a;
    --color-green-glow: rgba(34, 197, 94, 0.25);
    --color-gold: #d4a853;
    --color-gold-light: #e8c97a;
    --color-text: #f0f0f0;
    --color-text-muted: #9ca3af;
    --color-text-dim: #6b7280;
    --color-border: rgba(255, 255, 255, 0.08);
    --color-border-strong: rgba(255, 255, 255, 0.15);
    --color-red: #ef4444;
    --color-red-dim: rgba(239, 68, 68, 0.15);
    --font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;
    --radius-xl: 24px;
    --shadow-glow: 0 0 20px rgba(34, 197, 94, 0.15);
    --shadow-glow-strong: 0 0 40px rgba(34, 197, 94, 0.25);
    --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-family);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    zoom: 0.85;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img, video {
    max-width: 100%;
    display: block;
  }

  button {
    cursor: pointer;
    font-family: inherit;
    border: none;
    outline: none;
  }

  input {
    font-family: inherit;
    outline: none;
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: var(--color-bg);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--color-green-dark);
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--color-green);
  }

  /* RTL & Font Swap */
  html[lang="ar"] body {
    font-family: 'Cairo', var(--font-family);
  }
  
  html[dir="rtl"] body {
    text-align: right;
  }
</style>
